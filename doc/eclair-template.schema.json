{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/eclair-template.schema.json",
  "title": "Eclair Template",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "kind", "description"],
  "properties": {
    "title": { "type": "string" },
    "kind": { "enum": ["ruleset", "variant", "tailoring"] },
    "description": { "type": "string" },
    "authors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "provides": { "$ref": "#/$defs/stringMapOrList" },
    "requires": { "$ref": "#/$defs/stringMapOrList" },
    "deps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "options": {
      "type": "array",
      "items": { "$ref": "#/$defs/option" }
    }
  },
  "$defs": {
    "stringMapOrList": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" },
              { "type": "null" },
              { "$ref": "#/$defs/anyDataValue" },
              { "type": "array", "items": { "$ref": "#/$defs/anyDataValue" } }
            ]
          }
        },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "anyDataValue": {
      "anyOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/anyDataValue" }
        },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/anyDataValue" }
        }
      ]
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "kind": { "enum": ["group", "flag", "select"] },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/option" }
        },
        "default": { "anyOf": [{ "type": "boolean" }, { "type": "string" }] },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "anyOf": [
              { "type": "string" },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["value"],
                "properties": {
                  "value": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            ]
          }
        },
        "variant": {
          "anyOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "children"],
              "properties": {
                "kind": { "const": "group" },
                "children": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/option" }
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind"],
              "properties": {
                "kind": { "const": "flag" },
                "default": { "type": "boolean" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "values", "default"],
              "properties": {
                "kind": { "const": "select" },
                "values": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "anyOf": [
                      { "type": "string" },
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["value"],
                        "properties": {
                          "value": { "type": "string" },
                          "description": { "type": "string" }
                        }
                      }
                    ]
                  }
                },
                "default": { "type": "string" }
              }
            }
          ]
        }
      },
      "anyOf": [
        { "required": ["kind"] },
        { "required": ["variant"] }
      ],
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "group" } }, "required": ["kind"] },
          "then": { "required": ["children"] }
        },
        {
          "if": { "properties": { "kind": { "const": "flag" } }, "required": ["kind"] },
          "then": { "properties": { "default": { "type": "boolean" }, "children": false } }
        },
        {
          "if": { "properties": { "kind": { "const": "select" } }, "required": ["kind"] },
          "then": { "required": ["values", "default"], "properties": { "default": { "type": "string" }, "children": false } }
        }
      ]
    }
  }
}
